{% extends 'auth.base' %}

{% block title %}{{ trans('LittleSkin\\YggdrasilConnect::front-end.device.title') }}{% endblock %}

{% block content %}
<p class="login-box-msg">{{ trans('LittleSkin\\YggdrasilConnect::front-end.device.description') }}</p>
<main>
    {% if success %}
    <div class="alert alert-success">{{ trans('LittleSkin\\YggdrasilConnect::front-end.device.success') }}</div>
    {% elseif select_profile %}
    <form id="device-profile-form" method="post" action="{{ url('/yggc/device') }}">
        {{ csrf_field() }}
        <input type="hidden" name="user_code" value="{{ user_code }}">
        <div class="form-group">
            <label for="profile-dropdown">{{ trans('LittleSkin\\YggdrasilConnect::front-end.select-profile.select-profile') }}</label>
            <select required class="form-control" name="profile_uuid" id="profile-dropdown">
                <option hidden value>{{ trans('LittleSkin\\YggdrasilConnect::front-end.select-profile.select-profile-dropdown-hidden') }}</option>
                {% for profile in availableProfiles %}
                    <option value="{{ profile.id }}">{{ profile.name }}</option>
                {% endfor %}
            </select>
        </div>
        {% if error %}
        <div class="alert alert-danger">{{ error }}</div>
        {% endif %}
        <div class="alert alert-warning">{{ trans('LittleSkin\\YggdrasilConnect::front-end.device.warning') }}</div>
        <button class="btn btn-primary btn-block" type="submit">{{ trans('LittleSkin\\YggdrasilConnect::front-end.device.confirm') }}</button>
    </form>
    {% else %}
    <form id="device-form" method="post" action="{{ url('/yggc/device') }}">
        {{ csrf_field() }}
        <div class="form-group">
            <label for="user_code">{{ trans('LittleSkin\\YggdrasilConnect::front-end.device.user-code') }}</label>
            <input type="text" class="form-control" name="user_code" id="user_code" placeholder="XXXX-XXXX" value="{{ user_code|default('') }}" required autofocus pattern="[A-Za-z0-9]{4}-[A-Za-z0-9]{4}">
        </div>
        {% if error %}
        <div class="alert alert-danger">{{ error }}</div>
        {% endif %}
        <div class="alert alert-warning">{{ trans('LittleSkin\\YggdrasilConnect::front-end.device.warning') }}</div>
        <button class="btn btn-primary btn-block" type="submit">{{ trans('LittleSkin\\YggdrasilConnect::front-end.device.confirm') }}</button>
    </form>
    {% endif %}
</main>
{% endblock %}
